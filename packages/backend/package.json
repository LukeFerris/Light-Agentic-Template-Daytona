{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --format=cjs --external:@aws-sdk/*",
    "build:server": "esbuild src/dev.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --format=cjs",
    "type-check": "tsc --noEmit",
    "start": "node dist/server.js",
    "dev": "yarn build:server && node dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "*",
    "@aws-sdk/client-s3": "*"
  },
  "devDependencies": {
    "@types/aws-lambda": "*",
    "@types/node": "*",
    "esbuild": "*",
    "typescript": "*"
  }
}
