# Copy to .env (gitignored) in the MAIN work tree and fill in. The Daytona loop
# and post-commit hook resolve this file from the main checkout, so card
# worktrees inherit it — no need for a copy in each worktree.
# Get a key from https://app.daytona.io (Settings -> API Keys; $200 free credit).
DAYTONA_API_KEY=dtn_xxx

# --- Optional overrides (sensible defaults in scripts/daytona/harness.mjs) ---
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_CPU=1               # snapshot vCPUs (default 1 — larger boxes may not place)
# DAYTONA_MEMORY=2            # snapshot memory in GiB (default 2)
# DAYTONA_DISK=5              # snapshot disk in GiB (default 5)
# DAYTONA_BOOT_RETRY_SECONDS=600  # how long to retry "No available runners" while a
#                                 # freshly-baked snapshot warms onto a runner
# REBUILD_SNAPSHOT=1          # force a fresh base snapshot (e.g. after a deps change)
# KEEP_SANDBOX=1              # leave the sandbox running for debugging
# DAYTONA_POST_COMMIT=1       # enable the opt-in .husky/post-commit loop
